{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nyx",
  "version": "0.1.0",
  "identifier": "com.netsirk.nyx",
  "build": {
    "beforeDevCommand": "bun run --filter @nyx/frontend dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run --filter @nyx/frontend build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nyx",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../../crates/nyx-core/resources/claude-plugin/.claude-plugin/marketplace.json": "resources/claude-plugin/.claude-plugin/marketplace.json",
      "../../../crates/nyx-core/resources/claude-plugin/.claude-plugin/plugin.json": "resources/claude-plugin/.claude-plugin/plugin.json",
      "../../../crates/nyx-core/resources/claude-plugin/hooks/hooks.json": "resources/claude-plugin/hooks/hooks.json",
      "../../../crates/nyx-core/resources/claude-plugin/hooks/nyx-session-hook.cjs": "resources/claude-plugin/hooks/nyx-session-hook.cjs",
      "../../../crates/nyx-core/resources/claude-plugin/.mcp.json": "resources/claude-plugin/.mcp.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
