{
  "name": "@nyx/electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for nyx (Chromium + Wayland-native). Main process, frameless single-instance window, dev/prod wiring, allowlisted preload, and the dedicated core-host (ELECTRON_RUN_AS_NODE).",
  "main": "dist/main/index.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:main": "node scripts/bundle.cjs",
    "build:renderer": "bun run --filter @nyx/frontend build",
    "build:renderer:e2e": "bun run --filter @nyx/frontend build:e2e",
    "copy:renderer": "node scripts/copy-renderer.cjs",
    "copy:napi": "node scripts/copy-napi.cjs",
    "copy:resources": "node scripts/copy-resources.cjs",
    "build": "bun run build:main && bun run build:renderer && bun run copy:renderer && bun run copy:napi && bun run copy:resources",
    "build:e2e": "bun run build:main && bun run build:renderer:e2e && bun run copy:renderer && bun run copy:napi && bun run copy:resources",
    "dev": "node scripts/dev.cjs",
    "start": "electron .",
    "smoke:window": "electron scripts/smoke-window.cjs",
    "smoke:single-instance": "node scripts/smoke-single-instance.cjs",
    "smoke:core-host": "electron scripts/smoke-core-host.cjs",
    "smoke:flow-control": "node scripts/smoke-flow-control.cjs",
    "smoke:flow-control-live": "electron scripts/smoke-flow-control-live.cjs",
    "smoke:wayland-flags": "electron scripts/smoke-wayland-flags.cjs",
    "smoke:lifecycle": "electron scripts/smoke-lifecycle.cjs",
    "smoke:prod-load": "electron scripts/smoke-prod-load.cjs",
    "smoke:bridge-e2e": "electron scripts/smoke-bridge-e2e.cjs",
    "smoke:mcp-full-surface": "electron scripts/smoke-mcp-full-surface.cjs",
    "smoke:dev-launch": "node scripts/smoke-dev-launch.cjs",
    "smoke:dev-launch:prod": "electron scripts/smoke-dev-launch.cjs --prod",
    "package": "node scripts/package.cjs",
    "smoke:package": "node scripts/smoke-package.cjs",
    "gate:echo": "electron scripts/gate-echo-harness.cjs --mode=gate",
    "gate:echo-sanity": "electron scripts/gate-echo-harness.cjs --mode=sanity",
    "gate:phase7": "node scripts/gate-phase7.cjs"
  },
  "devDependencies": {
    "@nyx/napi": "workspace:*",
    "@types/node": "^22.10.0",
    "electron": "42.4.1",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "typescript": "~5.8.3"
  }
}
